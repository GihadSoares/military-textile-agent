# Copy this file to .env and fill in your real API keys.
# NEVER commit your real .env file to GitHub!

# Get your OpenAI API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Get your Firecrawl API key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here

# Optional: Make.com webhook URL for notifications (Telegram/Email/Discord)
# Leave blank to disable webhook notifications.
MAKE_WEBHOOK_URL=
